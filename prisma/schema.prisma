generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  phone          String   @unique
  name           String?
  metadata       String?
  monthlyIncome  Float?
  jornadaMinutos Int      @default(480)
  isPremium      Boolean  @default(false)
  blocked        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime? @updatedAt

  memories       Memory[]
  medications    Medication[]
  tasks          Task[]
  expenses       Expense[]
  purchases      Purchase[]
  secrets        Secret[]
  bills          Bill[]
  reminders      Reminder[]
  events         Event[]
  groceryLists   GroceryList[]
  sleepLogs      SleepLog[]
  workouts       Workout[]
  workLogs       WorkLog[]
  contacts          Contact[]
  scheduledMessages ScheduledMessage[]
  pendencias        Pendencia[]
}

model Contact {
  id        String    
