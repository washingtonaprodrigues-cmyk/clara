// não pelo Prisma) — declarado aqui só para o schema "bater" com o banco
// e o `prisma db push` parar de tentar recriar essa coluna.
enum InstanceConnectionStatus {
  open
  close
  connecting
}

model Instance {
  id                      String    @id
  name                    String
  connectionStatus        InstanceConnectionStatus
  ownerJid                String?
