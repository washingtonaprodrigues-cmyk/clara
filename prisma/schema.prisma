// Clara v4.0 - CRM de vida pessoal
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id          String       @id @default(cuid())
  phone       String       @unique
  name        String?
  metadata    String?
  createdAt   DateTime     @default(now())
  memories    Memory[]
  medications Medication[]
  tasks       Task[]
  expenses    Expense[]
  secrets     Secret[]
  purchases   Purchase[]
  reminders   Reminder[]
  events      Event[]
  habits      Habit[]
  habitLogs   HabitLog[]
  groceryLists GroceryList[]
  sleepLogs   SleepLog[]
  workouts    Workout[]
  notes       Note[]
}
model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
}
model Medication {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  totalPills Int      @default(0)
  remaining  Int      @default(0)
  frequency  Int      @default(1)
  times      String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}
model Task {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String
  dueDate   DateTime?
  dueTime   String?
  items     String?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
}
model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  value       Float
  category    String
  description String?
  createdAt   DateTime @default(now())
}
model Secret {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  category  String?
  label     String?
  createdAt DateTime @default(now())
}
model Purchase {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  item         String
  lastBought   DateTime @default(now())
  buyCount     Int      @default(1)
  avgFrequency Int?
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now())
}
model Reminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phone       String
  message     String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  confirmed   Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())
}
model Event {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String
  personName String?
  personAge  Int?
  date       DateTime
  type       String   @default("outro")
  notified   Boolean  @default(false)
  createdAt  DateTime @default(now())
}
model Habit {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  name      String
  frequency String     @default("diario")
  active    Boolean    @default(true)
  logs      HabitLog[]
  createdAt DateTime   @default(now())
}
model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  done      Boolean  @default(true)
}
model GroceryList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  items     String
  createdAt DateTime @default(now())
}
model SleepLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  bedtime   String?
  wakeTime  String?
  quality   String?
  hours     Float?
  createdAt DateTime @default(now())
}
model Workout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  duration  Int?
  exercises String?
  note      String?
  createdAt DateTime @default(now())
}
model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
