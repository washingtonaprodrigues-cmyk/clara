// src/services/prisma.js
// Instância única do PrismaClient para todo o projeto.
// Evita múltiplos pools de conexão que causam "concurrency limit reached".

const { PrismaClient } = require('@prisma/client');

const prisma = new PrismaClient({
  datasources: {
    db: {
      url: process.env.DATABASE_URL,
    },
  },
  // Pool de conexões controlado — máximo 5 conexões simultâneas
  // suficiente para o volume atual sem estourar o limite do Railway
  log: process.env.NODE_ENV === 'development' ? ['error'] : ['error'],
});

// Graceful shutdown
process.on('beforeExit', async () => {
  await prisma.$disconnect();
});

module.exports = prisma;
