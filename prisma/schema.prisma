generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  phone          String   @unique
  name           String?
  metadata       String?
  monthlyIncome  Float?
  jornadaMinutos Int      @default(480)
  isPremium      Boolean  @default(false)
  blocked        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime? @updatedAt

  memories       Memory[]
  medications    Medication[]
  tasks          Task[]
  expenses       Expense[]
  purchases      Purchase[]
  secrets        Secret[]
  bills          Bill[]
  reminders      Reminder[]
  events         Event[]
  groceryLists   GroceryList[]
  sleepLogs      SleepLog[]
  workouts       Workout[]
  workLogs       WorkLog[]
  contacts          Contact[]
  scheduledMessages ScheduledMessage[]
  pendencias        Pendencia[]
}

model Contact {
  id        String    @id @default(cuid())
  userId    String
  name      String
  phone     String
  relation  String?   // ex: esposa, amigo, chefe, filho
  notes     String?   // info extra: "gosta de futebol", "aniversário em março"
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, phone])
}

model Memory {
  id        String    @id @default(cuid())
  userId    String
  type      String
  content   String
  metadata  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
}

model Medication {
  id         String    @id @default(cuid())
  userId     String
  name       String
  totalPills Int       @default(0)
  remaining  Int       @default(0)
  frequency  Int       @default(1)
  times      String
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?

  user       User      @relation(fields: [userId], references: [id])
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  title     String
  dueDate   DateTime?
  dueTime   String?
  completed Boolean   @default(false)
  done      Boolean   @default(false)
  notified  Boolean   @default(false)
  items     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
}

model Expense {
  id          String    @id @default(cuid())
  userId      String
  value       Float
  category    String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String?
  phone       String
  message     String
  scheduledAt DateTime
  sent        Boolean   @default(false)
  confirmed   Boolean   @default(false)
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  user        User?     @relation(fields: [userId], references: [id])
}

// Pendência emocional/de saúde — algo passageiro que o usuário mencionou
// (mal-estar, evento com resultado incerto: entrevista, prova, consulta)
// e que vale a pena a Clara voltar a perguntar depois, sem esperar o
// usuário trazer o assunto de novo. Ver extractPendenciaEmocional (groq.js),
// cron "PENDÊNCIAS EMOCIONAIS" (reminders.js) e o branch correspondente em
// checkConfirmacaoPendente (handler.js).
model Pendencia {
  id         String    @id @default(cuid())
  userId     String
  categoria  String    // 'saude' | 'evento'
  resumo     String    // ex: "dor de cabeça", "entrevista de emprego"
  checkInAt  DateTime  // quando a Clara deve voltar a perguntar
  perguntado Boolean   @default(false)
  resolvido  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?

  user       User      @relation(fields: [userId], references: [id])
}

model Purchase {
  id           String    @id @default(cuid())
  userId       String
  item         String
  lastBought   DateTime  @default(now())
  buyCount     Int       @default(1)
  avgFrequency Int?
  notified     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime?

  user         User      @relation(fields: [userId], references: [id])
}

model Event {
  id         String    @id @default(cuid())
  userId     String
  title      String
  personName String?
  personAge  Int?
  date       DateTime
  type       String    @default("outro")
  notified   Boolean   @default(false)
  followedUp Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime?

  user       User      @relation(fields: [userId], references: [id])
}

model WorkLog {
  id        String    @id @default(cuid())
  userId    String?
  type      String?
  timestamp DateTime?
  date      String?
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [userId], references: [id])
}

model Secret {
  id        String    @id @default(cuid())
  userId    String
  title     String
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
}

model Bill {
  id          String    @id @default(cuid())
  userId      String
  title       String
  amount      Float
  dueDate     DateTime?
  paid        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id])
}

model GroceryList {
  id        String    @id @default(cuid())
  userId    String
  name      String
  items     String
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  user      User      @relation(fields: [userId], references: [id])
}

model SleepLog {
  id        String    @id @default(cuid())
  userId    String
  bedTime   DateTime?
  wakeTime  DateTime?
  quality   Int?
  notes     String?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
}

model Workout {
  id        String    @id @default(cuid())
  userId    String
  type      String
  duration  Int?
  notes     String?
  date      DateTime  @default(now())
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id])
}


model ScheduledMessage {
  id          String   @id @default(cuid())
  userId      String
  fromPhone   String
  toPhone     String
  toName      String?
  message     String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

// ── Tabelas da Evolution API / UazAPI (não gerenciadas pelo app) ──

model Instance {
  id                      String    @id
  name                    String
  connectionStatus        String
  ownerJid                String?
  profilePicUrl           String?
  integration             String?
  number                  String?
  token                   String?
  clientName              String?
  profileName             String?
  businessId              String?
  disconnectionAt         DateTime?
  disconnectionObject     Json?
  disconnectionReasonCode Int?
  createdAt               DateTime?
  updatedAt               DateTime?

  settings                Setting[]
}

model Session {
  id        String   @id
  sessionId String
  creds     String?
  createdAt DateTime
}

model Setting {
  id              String    @id
  rejectCall      Boolean
  msgCall         String?
  groupsIgnore    Boolean
  alwaysOnline    Boolean
  readMessages    Boolean
  readStatus      Boolean
  syncFullHistory Boolean
  wavoipToken     String?
  instanceId      String
  createdAt       DateTime?
  updatedAt       DateTime

  instance        Instance  @relation(fields: [instanceId], references: [id])
}
