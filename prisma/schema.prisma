// Clara v4.1
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  phone         String        @unique
  name          String?
  metadata      String?
  monthlyIncome Float?
  isPremium     Boolean       @default(false)
  blocked       Boolean       @default(false)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  memories      Memory[]
  medications   Medication[]
  tasks         Task[]
  expenses      Expense[]
  purchases     Purchase[]
  secrets       Secret[]
  bills         Bill[]
  reminders     Reminder[]
  events        Event[]
  groceryLists  GroceryList[]
  sleepLogs     SleepLog[]
  workouts      Workout[]
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String
  content   String
  metadata  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Medication {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  name       String
  totalPills Int      @default(0)
  remaining  Int      @default(0)
  frequency  Int      @default(1)
  times      String
  active     Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  title     String
  dueDate   DateTime?
  dueTime   String?
  completed Boolean   @default(false)
  notified  Boolean   @default(false)
  items     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  value       Float
  category    String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Bill {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])

  name      String
  value     Float?
  dueDay    Int?
  paid      Boolean   @default(false)
  paidAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  item         String
  lastBought   DateTime @default(now())
  buyCount     Int      @default(1)
  avgFrequency Int?
  notified     Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model Secret {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  content   String
  category  String
  label     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  phone       String
  message     String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  confirmed   Boolean  @default(false)
  attempts    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Event {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  title      String
  personName String?
  personAge  Int?
  date       DateTime
  type       String   @default("outro")
  notified   Boolean  @default(false)
  followedUp Boolean  @default(false)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model GroceryList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  items     String
  total     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model SleepLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  bedtime   String?
  wakeTime  String?
  hours     Float?
  quality   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String
  duration  Int?
  exercises String?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}
