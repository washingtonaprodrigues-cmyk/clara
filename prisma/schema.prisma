// Clara v1.1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  phone       String       @unique
  name        String?
  createdAt   DateTime     @default(now())
  memories    Memory[]
  medications Medication[]
  tasks       Task[]
  expenses    Expense[]
  secrets     Secret[]
  purchases   Purchase[]
  reminders   Reminder[]
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Medication {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  name       String
  totalPills Int      @default(0)
  remaining  Int      @default(0)
  frequency  Int      @default(1)
  times      String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Task {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String
  dueDate   DateTime?
  dueTime   String?
  completed Boolean   @default(false)
  notified  Boolean   @default(false)
  items     String?
  createdAt DateTime  @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  value       Float
  category    String
  description String
  createdAt   DateTime @default(now())
}

model Secret {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  category  String
  label     String
  createdAt DateTime @default(now())
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  user         User
